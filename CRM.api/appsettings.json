{
  "ConnectionStrings": {    
    "DefaultConnection": "YOUR_CONNECTION_STRING"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtSettings": {
    "Key": "YOUR_SECRET_KEY",
    "Issuer": "CrmApi",
    "Audience": "CrmApiUsers",
    "DurationInMinutes": 60
  },


  "AllowedHosts": "*"
}
